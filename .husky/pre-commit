#!/usr/bin/env sh
# Pre-commit hook: scan the staged diff for accidentally-committed secrets.
#
# Uses gitleaks if installed locally; otherwise prints an install hint and
# allows the commit through (rather than blocking unrelated work when the
# user hasn't set up the tool yet — opinionated trade-off).
#
# To install gitleaks:
#   macOS:        brew install gitleaks
#   Linux:        see https://github.com/gitleaks/gitleaks#installing
#   With Go:      go install github.com/gitleaks/gitleaks/v8@latest
#
# To bypass this hook for a single commit (rare; e.g. a docs commit that
# legitimately contains a string that looks key-shaped):
#   git commit --no-verify
# Don't make a habit of it.

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner --verbose
  status=$?
  if [ $status -ne 0 ]; then
    echo
    echo "🛑 gitleaks detected potential secrets in the staged diff."
    echo "   Review the findings above and remove the secret(s) before committing."
    echo "   To bypass (rare — be sure first): git commit --no-verify"
    exit $status
  fi
else
  echo "⚠  gitleaks not installed — skipping pre-commit secret scan."
  echo "   This repo is PUBLIC. Install gitleaks to catch accidental key commits:"
  echo "     brew install gitleaks    # macOS"
  echo "     https://github.com/gitleaks/gitleaks    # other platforms"
fi
